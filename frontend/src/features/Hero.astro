---
import { basics } from "@resume";
import ContactLinks from "@/components/ContactLinks.astro";
import GitHub from "@/icons/GitHub.astro";
import LinkedIn from "@/icons/LinkedIn.astro";

const { name, label, email, profiles, location } = basics;
const { city, region, countryCode } = location;

const SOCIAL_MEDIA_ICONS: Record<string, any> = {
  LinkedIn,
  GitHub,
};
---

<section
  class="relative flex min-h-screen items-center px-8 pt-36 pb-20 max-[768px]:px-5 max-[768px]:pt-28 max-[768px]:pb-12"
  id="hero"
>
  <div
    class="mx-auto grid w-full max-w-[1180px] grid-cols-1 items-center gap-10 min-[980px]:grid-cols-[1.05fr_0.95fr] min-[980px]:gap-14"
  >
    <div class="animate-[slide-in-left_0.7s_ease]">
      <span class="eyebrow eyebrow-accent mb-5 block">
        Backend · Security · Fullstack
      </span>
      <h1 class="aurora-text m-0 mb-2 text-[clamp(2.6rem,6vw,4.25rem)]">
        {name}
      </h1>
      <p
        class="text-secondary m-0 mb-6 font-sans text-[clamp(1rem,2vw,1.2rem)] font-medium"
      >
        {label}
      </p>
      <p class="m-0 mb-8 max-w-[46ch] text-[1.08rem]">
        I&rsquo;m a senior software engineer working across backend, full-stack,
        and application security, designing reliable services, clean APIs, and
        the systems that keep them safe.
      </p>

      <dl class="border-border mb-8 flex flex-col gap-2.5 border-l pl-4">
        <div class="flex items-baseline gap-3.5">
          <dt class="text-secondary min-w-14 font-mono text-[0.78rem]">Role</dt>
          <dd class="text-text m-0 text-[0.95rem]">
            Backend / Application Security / Fullstack
          </dd>
        </div>
        <div class="flex items-baseline gap-3.5">
          <dt class="text-secondary min-w-14 font-mono text-[0.78rem]">
            Stack
          </dt>
          <dd class="text-text m-0 text-[0.95rem]">
            NodeJs · TypeScript · Amazon Web Services · AppSec
          </dd>
        </div>
        <div class="flex items-baseline gap-3.5">
          <dt class="text-secondary min-w-14 font-mono text-[0.78rem]">
            Based
          </dt>
          <dd class="text-text m-0 text-[0.95rem]">
            {city}, {region} &mdash; {countryCode}
          </dd>
        </div>
      </dl>

      <div class="flex flex-wrap gap-3">
        <ContactLinks
          email={email}
          profiles={profiles}
          socialMediaIcons={SOCIAL_MEDIA_ICONS}
        />
      </div>
    </div>

    <div
      class="relative h-[460px] animate-[fade-in-soft_0.8s_ease_0.4s_backwards] max-[980px]:flex max-[980px]:h-auto max-[980px]:flex-wrap max-[980px]:justify-center max-[980px]:gap-4"
    >
      <div
        class="card absolute top-[8%] right-[8%] flex animate-[float_3s_ease-in-out_infinite] items-center gap-3.5 px-6 py-5 shadow-[0_10px_40px_rgba(0,0,0,0.12)] max-[980px]:static"
      >
        <span
          class="from-primary to-secondary flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br text-white shadow-[0_8px_20px_-8px_var(--color-primary)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="2" y="2" width="20" height="8" rx="2"></rect>
            <rect x="2" y="14" width="20" height="8" rx="2"></rect>
            <line x1="6" y1="6" x2="6.01" y2="6"></line>
            <line x1="6" y1="18" x2="6.01" y2="18"></line>
          </svg>
        </span>
        <span class="text-text font-display font-semibold">Backend</span>
      </div>

      <div
        class="card absolute top-[42%] right-[28%] flex animate-[float_3s_ease-in-out_1s_infinite] items-center gap-3.5 px-6 py-5 shadow-[0_10px_40px_rgba(0,0,0,0.12)] max-[980px]:static"
      >
        <span
          class="from-secondary to-accent flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br text-white shadow-[0_8px_20px_-8px_var(--color-secondary)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
        </span>
        <span class="text-text font-display font-semibold">Security</span>
      </div>

      <div
        class="card absolute right-[4%] bottom-[12%] flex animate-[float_3s_ease-in-out_0.5s_infinite] items-center gap-3.5 px-6 py-5 shadow-[0_10px_40px_rgba(0,0,0,0.12)] max-[980px]:static"
      >
        <span
          class="from-accent to-primary flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br text-white shadow-[0_8px_20px_-8px_var(--color-accent)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <polyline points="16 18 22 12 16 6"></polyline>
            <polyline points="8 6 2 12 8 18"></polyline>
          </svg>
        </span>
        <span class="text-text font-display font-semibold">Fullstack</span>
      </div>
    </div>
  </div>

  <a
    class="text-text-light absolute bottom-8 left-1/2 hidden -translate-x-1/2 flex-col items-center gap-1.5 font-mono text-[0.75rem] min-[980px]:flex"
    href="#about"
  >
    <span>scroll</span>
    <span class="animate-[nudge_1.8s_ease_infinite]" aria-hidden="true">
      &darr;
    </span>
  </a>
</section>
