---
import { api } from "@/api/api-client.ts";
import ApiError from "@/components/ApiError.astro";
import Lightbox from "@/components/Lightbox.svelte";
import Section from "@/components/Section.astro";
import type { CareerCertifications } from "@/types/types.ts";
import { API_PATHS } from "@/utils/constants.ts";
import { asyncThrowable } from "@/utils/utils.ts";

export const prerender = false;

const [certifications, error] = await asyncThrowable<CareerCertifications>(() =>
  api.get<CareerCertifications>(API_PATHS.UPLOAD_CERTIFICATES)
);

const hasError = error !== null;

const certImages =
  certifications?.map((cert) => ({
    url: cert.file_url,
    title: cert.title,
    issuer: cert.issuer,
    date: new Date(cert.issue_date).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
    }),
  })) ?? [];
---

<Section title="Certifications" id="certifications" index={6}>
  <ApiError hasError={hasError} error={error} data={certifications} />
  {
    !hasError && certifications && certifications.length > 0 && (
      <Lightbox client:visible images={certImages} />
    )
  }
</Section>
