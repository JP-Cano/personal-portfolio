---
import { basics } from "@resume";
import Section from "@/components/Section.astro";

const { summary } = basics;

const stats = [
  {
    value: "5+",
    label: "years building backends",
  },
  {
    value: "5+",
    label:
      "domains shipped — fintech, healthtech, comms, academic, cybersecurity",
  },
  {
    value: "8-10",
    label: "engineers per cross-functional team",
  },
];
---

<Section title="About" id="about" index={1}>
  <div class="mx-auto w-full max-w-[920px] text-center">
    <p
      class="text-text-light mb-12 text-[1.1rem] leading-[1.8] max-[768px]:text-base"
    >
      {summary}
    </p>
    <div
      class="grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-4 max-[768px]:grid-cols-1"
    >
      {
        stats.map((stat) => (
          <div class="card card-hover px-6 py-7">
            <div class="aurora-text font-display mb-3.5 text-[2.75rem] leading-none font-semibold max-[768px]:text-[2.25rem]">
              {stat.value}
            </div>
            <div class="text-text-light font-mono text-[0.8rem] leading-[1.5] tracking-[0.02em] lowercase">
              {stat.label}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</Section>
