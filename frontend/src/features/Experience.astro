---
export const prerender = false;

import { api } from "@/api/api-client.ts";
import ApiError from "@/components/ApiError.astro";
import Section from "@/components/Section.astro";
import type { Experiences } from "@/types/types.ts";
import { API_PATHS } from "@/utils/constants.ts";
import { asyncThrowable } from "@/utils/utils.ts";

const [experiences, error] = await asyncThrowable<Experiences>(() =>
  api.get<Experiences>(API_PATHS.EXPERIENCES)
);

const hasError = error !== null;
---

<Section title="Experience" id="experience" index={2}>
  <ApiError hasError={hasError} error={error} data={experiences} />

  {
    !hasError && experiences && experiences.length > 0 && (
      <div class="relative w-full">
        {experiences.map((experience, index) => {
          const displayData = {
            id: experience.id,
            company: experience.company,
            url: experience.url || "#",
            title: experience.title,
            location: experience.location,
            type: experience.type,
            startDate: experience.startDate,
            endDate: experience.endDate,
            description: experience.description,
          };

          const startYear = new Date(displayData.startDate).getFullYear();
          const endYear = displayData.endDate
            ? new Date(displayData.endDate).getFullYear()
            : "Present";
          const isLast = index === experiences.length - 1;

          return (
            <div class="group grid grid-cols-[34px_1fr] gap-4 md:grid-cols-[50px_1fr] md:gap-8">
              <div class="flex flex-col items-center pt-2">
                <span class="from-primary to-secondary h-4 w-4 shrink-0 rounded-full bg-gradient-to-br shadow-[0_0_0_4px_var(--color-bg),0_0_0_6px_var(--color-primary)] transition-transform duration-300 group-hover:scale-125 md:h-5 md:w-5" />
                {!isLast && (
                  <span class="from-primary mt-2 w-0.5 flex-1 bg-gradient-to-b to-transparent" />
                )}
              </div>

              <div class={isLast ? "min-w-0 pb-1" : "min-w-0 pb-12"}>
                <article
                  class="card card-hover relative w-full cursor-pointer overflow-hidden p-6 md:p-8"
                  onclick={`window.location.href='/experience/${displayData.id}'`}
                  role="main"
                  tabindex="0"
                  onkeydown={(e) => {
                    if (e.key === "Enter" || e.key === " ") {
                      window.location.href = `/experience/${displayData.id}`;
                    }
                  }}
                >
                  <div class="mb-5 flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                    <div class="min-w-0 flex-1">
                      <h3 class="m-0 text-[1.3rem] leading-tight break-words md:text-[1.5rem]">
                        {displayData.company}
                      </h3>
                      <h4 class="text-text-light m-0 mt-1.5 text-[1.05rem] font-semibold break-words">
                        {displayData.title}
                      </h4>
                      {displayData.location && displayData.type && (
                        <p class="text-text-light m-0 mt-2 flex flex-wrap items-center gap-2 text-sm break-words">
                          {displayData.location} • {displayData.type}
                        </p>
                      )}
                    </div>
                    <div class="bg-bg-alt text-text inline-flex shrink-0 items-center gap-2 self-start rounded-full px-4 py-2 text-sm font-semibold whitespace-nowrap">
                      <time datetime={displayData.startDate.toString()}>
                        {startYear}
                      </time>
                      <span aria-hidden="true">–</span>
                      <time datetime={displayData.endDate?.toString() || ""}>
                        {endYear}
                      </time>
                    </div>
                  </div>

                  {displayData.description && (
                    <p class="text-text-light m-0 text-base leading-relaxed break-words">
                      {displayData.description}
                    </p>
                  )}

                  <div class="mt-5 flex flex-wrap items-center gap-4">
                    <span class="text-primary inline-flex items-center gap-1.5 text-sm font-semibold">
                      View details
                      <span
                        aria-hidden="true"
                        class="transition-transform duration-200 group-hover:translate-x-1"
                      >
                        →
                      </span>
                    </span>
                  </div>
                </article>
              </div>
            </div>
          );
        })}
      </div>
    )
  }
</Section>
