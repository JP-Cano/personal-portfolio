---
import { skills } from "@resume";
import Section from "@/components/Section.astro";
import AWS from "@/icons/Aws.astro";
import ChatGPT from "@/icons/ChatGPT.astro";
import ClaudeCode from "@/icons/ClaudeCode.astro";
import Codex from "@/icons/Codex.astro";
import Cursor from "@/icons/Cursor.astro";
import Docker from "@/icons/Docker.astro";
import DynamoDB from "@/icons/DynamoDB.astro";
import ElasticSearch from "@/icons/ElasticSearch.astro";
import Git from "@/icons/Git.astro";
import GitHub from "@/icons/GitHub.astro";
import GitLab from "@/icons/GitLab.astro";
import Go from "@/icons/Go.astro";
import GraphQL from "@/icons/Graphql.astro";
import JavaScript from "@/icons/JavaScript.astro";
import Jest from "@/icons/Jest.astro";
import JetBrainsAI from "@/icons/JetBrainsAI.astro";
import Junie from "@/icons/Junie.astro";
import Kafka from "@/icons/Kafka.astro";
import Kubernetes from "@/icons/Kubernetes.astro";
import MongoDB from "@/icons/Mongo.astro";
import NestJs from "@/icons/NestJs.astro";
import NodeJs from "@/icons/Node.astro";
import PostgreSQL from "@/icons/PostgreSql.astro";
import QwenCoder from "@/icons/QwenCoder.astro";
import React from "@/icons/React.astro";
import Redis from "@/icons/Redis.astro";
import TypeScript from "@/icons/TypeScript.astro";

const SKILLS_ICONS: Record<string, any> = {
  NodeJs,
  NestJs,
  TypeScript,
  JavaScript,
  Git,
  PostgreSQL,
  Redis,
  ElasticSearch,
  DynamoDB,
  GitHub,
  AWS,
  Docker,
  Go,
  MongoDB,
  Kafka,
  Jest,
  Kubernetes,
  GitLab,
  GraphQL,
  React,
  Cursor,
  ClaudeCode,
  JetBrainsAI,
  Junie,
  ChatGPT,
  QwenCoder,
  Codex,
};

const skillCategories = [
  {
    title: "Languages & Frameworks",
    skills: skills.filter((s) =>
      [
        "NodeJs",
        "NestJs",
        "TypeScript",
        "JavaScript",
        "Go",
        "React",
        "GraphQL",
      ].includes(s.name)
    ),
  },
  {
    title: "Databases",
    skills: skills.filter((s) =>
      ["PostgreSQL", "MongoDB", "Redis", "ElasticSearch", "DynamoDB"].includes(
        s.name
      )
    ),
  },
  {
    title: "AI Tools",
    skills: skills.filter((s) =>
      [
        "Cursor",
        "ClaudeCode",
        "JetBrainsAI",
        "Junie",
        "ChatGPT",
        "QwenCoder",
        "Codex",
      ].includes(s.name)
    ),
  },
  {
    title: "DevOps & Tools",
    skills: skills.filter((s) =>
      [
        "Docker",
        "Kubernetes",
        "AWS",
        "Git",
        "GitHub",
        "GitLab",
        "Kafka",
        "Jest",
      ].includes(s.name)
    ),
  },
];
---

<Section title="Skills" id="skills" index={5}>
  <div
    class="grid grid-cols-[repeat(auto-fit,minmax(min(280px,100%),1fr))] gap-6 max-[768px]:grid-cols-1 max-[768px]:gap-5"
  >
    {
      skillCategories.map((category) => (
        <div class="card p-6">
          <div class="border-border mb-5 flex items-baseline justify-between gap-3 border-b pb-3.5">
            <span class="eyebrow">{category.title}</span>
            <span class="text-text-light font-mono text-[0.78rem]">
              {category.skills.length}
            </span>
          </div>
          <ul class="m-0 flex list-none flex-wrap gap-2.5 p-0">
            {category.skills.map(({ name }) => {
              const iconName = name === "Next.js" ? "Next" : name;
              const Icon = SKILLS_ICONS[iconName];

              return (
                <li class="group border-border bg-bg-alt hover:border-primary inline-flex items-center gap-2 rounded-sm border px-3 py-2 transition-[border-color,transform] duration-200 hover:-translate-y-0.5">
                  {Icon && (
                    <div class="skill-icon flex h-[22px] w-[22px] shrink-0 items-center justify-center [&_svg]:h-full [&_svg]:w-full">
                      <Icon />
                    </div>
                  )}
                  <span class="text-text-light group-hover:text-text font-mono text-[0.8rem] font-medium transition-colors duration-200">
                    {name}
                  </span>
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
  </div>
</Section>

<style>
  /* Narrow exception: recolor inline skill SVGs to the icon token. Tailwind
     can't target descendant SVG fills/strokes, and we must preserve outline
     (svg[fill="none"]) icons. No layout/color of the component lives here. */
  .skill-icon :global(svg) {
    color: var(--color-icon);
    transition:
      color 0.3s ease,
      fill 0.3s ease,
      stroke 0.3s ease;
  }

  .skill-icon :global(svg path),
  .skill-icon :global(svg g),
  .skill-icon :global(svg circle),
  .skill-icon :global(svg rect),
  .skill-icon :global(svg polygon) {
    fill: var(--color-icon);
    stroke: var(--color-icon);
  }

  .skill-icon :global(svg[fill="none"] path),
  .skill-icon :global(svg[fill="none"] circle),
  .skill-icon :global(svg[fill="none"] rect) {
    fill: none;
  }
</style>
