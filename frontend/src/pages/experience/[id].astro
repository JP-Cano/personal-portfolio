---
export const prerender = false;

import { api } from "@/api/api-client.ts";
import ApiError from "@/components/ApiError.astro";
import Footer from "@/components/Footer.astro";
import Navigation from "@/components/Navigation.astro";
import Layout from "@/layouts/Layout.astro";
import type { ExperienceDetail } from "@/types/types.ts";
import { experienceDetailSchema } from "@/types/types.ts";
import { API_PATHS } from "@/utils/constants.ts";
import { asyncThrowable } from "@/utils/utils.ts";

const { id } = Astro.params;

const [raw, fetchError] = await asyncThrowable(() =>
  api.get(`${API_PATHS.EXPERIENCES}/${id}`)
);

let experience: ExperienceDetail | null = null;
let hasError = fetchError !== null;
let error: unknown = fetchError;

if (!hasError) {
  const parsed = experienceDetailSchema.safeParse(raw);
  if (parsed.success) {
    experience = parsed.data;
  } else {
    hasError = true;
    error = parsed.error;
    console.error("Invalid experience detail payload:", parsed.error);
  }
}

const clients = experience?.clients ?? [];

const formatMonthYear = (date?: Date): string =>
  date
    ? new Date(date).toLocaleDateString("en-US", {
        month: "short",
        year: "numeric",
      })
    : "Present";

const pageTitle = experience
  ? `${experience.title} · ${experience.company}`
  : "Experience";
---

<Layout title={pageTitle}>
  <Navigation />

  <main class="min-h-screen px-4 pt-24 pb-12 md:px-6 md:pt-32 md:pb-16">
    <div class="mx-auto max-w-[900px]">
      <a
        href="/#experience"
        data-astro-reload
        class="text-text-light hover:text-primary mb-8 inline-block font-mono text-sm transition-colors"
      >
        ← Back to experience
      </a>

      {
        (hasError || !experience) && (
          <ApiError hasError={hasError} error={error} data={experience} />
        )
      }

      {
        !hasError && experience && (
          <article>
            <header class="border-border mb-10 border-b pb-8">
              <p class="eyebrow eyebrow-accent">
                {experience.location}
                {experience.location && experience.type ? " • " : ""}
                {experience.type}
              </p>
              <h1 class="mt-3.5 break-words">{experience.title}</h1>
              <p class="text-secondary mt-2.5 text-lg break-words">
                {experience.company}
              </p>
              {experience.url && (
                <a
                  href={experience.url}
                  target="_blank"
                  rel="noopener"
                  class="text-secondary hover:text-primary mt-2 inline-flex items-center gap-1.5 text-sm font-semibold transition-colors hover:underline"
                >
                  Visit website
                  <span aria-hidden="true">↗</span>
                </a>
              )}
              <p class="text-text-light mt-2 font-mono text-sm">
                {formatMonthYear(experience.startDate)} —{" "}
                {formatMonthYear(experience.endDate)}
              </p>
              {experience.description && (
                <p class="text-text-light mt-6 leading-relaxed break-words">
                  {experience.description}
                </p>
              )}
            </header>

            <section>
              <h2 class="mb-6">Clients & engagements</h2>

              {clients.length === 0 ? (
                <p class="text-text-light">No client details added yet.</p>
              ) : (
                <ul class="flex flex-col gap-6">
                  {clients.map((client) => (
                    <li class="card card-hover overflow-hidden p-6 md:p-8">
                      <div class="mb-4 flex flex-wrap items-start justify-between gap-4">
                        <h3 class="m-0 min-w-0 flex-1 text-[1.3rem] leading-tight break-words">
                          {client.url ? (
                            <a
                              href={client.url}
                              target="_blank"
                              rel="noopener"
                              class="hover:text-primary underline-offset-4 transition-colors hover:underline"
                            >
                              {client.name}
                            </a>
                          ) : (
                            client.name
                          )}
                        </h3>
                        <span class="chip shrink-0 whitespace-nowrap">
                          {formatMonthYear(client.startDate)} —{" "}
                          {formatMonthYear(client.endDate)}
                        </span>
                      </div>

                      {client.description && (
                        <p class="text-text-light mb-5 leading-relaxed break-words">
                          {client.description}
                        </p>
                      )}

                      {client.responsibilities.length > 0 && (
                        <div class="mt-5">
                          <h4 class="eyebrow eyebrow-accent mb-2.5 block">
                            Responsibilities
                          </h4>
                          <ul class="flex flex-col gap-2">
                            {client.responsibilities.map((item) => (
                              <li class="text-text before:text-secondary relative pl-6 leading-relaxed break-words before:absolute before:left-0 before:font-mono before:content-['▹']">
                                {item}
                              </li>
                            ))}
                          </ul>
                        </div>
                      )}

                      {client.achievements.length > 0 && (
                        <div class="mt-5">
                          <h4 class="eyebrow eyebrow-accent mb-2.5 block">
                            Achievements
                          </h4>
                          <ul class="flex flex-col gap-2">
                            {client.achievements.map((item) => (
                              <li class="text-text before:text-secondary relative pl-6 leading-relaxed break-words before:absolute before:left-0 before:font-mono before:content-['▹']">
                                {item}
                              </li>
                            ))}
                          </ul>
                        </div>
                      )}

                      {client.technologies.length > 0 && (
                        <div class="mt-5">
                          <h4 class="eyebrow eyebrow-accent mb-2.5 block">
                            Technologies
                          </h4>
                          <div class="flex flex-wrap gap-2">
                            {client.technologies.map((tech) => (
                              <span class="chip">{tech}</span>
                            ))}
                          </div>
                        </div>
                      )}
                    </li>
                  ))}
                </ul>
              )}
            </section>
          </article>
        )
      }
    </div>
  </main>

  <Footer />
</Layout>
