---
export const prerender = false;

import { api } from "@/api/api-client";
import ProjectsManager from "@/components/admin/ProjectsManager.svelte";
import AdminLayout from "@/layouts/AdminLayout.astro";
import type { Projects } from "@/types/types";
import { API_PATHS } from "@/utils/constants";

const user = Astro.locals.user;

let projects: Projects = [];
let error: string | null = null;

try {
  projects = await api.get<Projects>(API_PATHS.PROJECTS);
} catch (err) {
  error = err instanceof Error ? err.message : "Failed to load projects";
}

const toIso = (date: Date | string | undefined): string =>
  date ? new Date(date).toISOString() : "";

const rows = projects.map((project) => ({
  id: project.id,
  name: project.name,
  description: project.description,
  url: project.url ?? "",
  startDate: toIso(project.startDate),
  endDate: toIso(project.endDate),
  technologies: project.technologies ?? "",
}));
---

<AdminLayout title="Projects" currentPath="/admin/projects" user={user}>
  {error && <div class="admin-alert admin-alert-error">{error}</div>}

  <ProjectsManager client:load projects={rows} />
</AdminLayout>
