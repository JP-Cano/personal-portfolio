---
export const prerender = false;

import { api } from "@/api/api-client";
import ExperiencesManager from "@/components/admin/ExperiencesManager.svelte";
import AdminLayout from "@/layouts/AdminLayout.astro";
import type { Experiences } from "@/types/types";
import { API_PATHS } from "@/utils/constants";

const user = Astro.locals.user;

let experiences: Experiences = [];
let error: string | null = null;

try {
  experiences = await api.get<Experiences>(API_PATHS.EXPERIENCES);
} catch (err) {
  error = err instanceof Error ? err.message : "Failed to load experiences";
}

const toIso = (date: Date | string | undefined): string =>
  date ? new Date(date).toISOString() : "";

const rows = experiences.map((exp) => ({
  id: exp.id,
  title: exp.title,
  company: exp.company,
  url: exp.url ?? "",
  location: exp.location,
  type: exp.type,
  startDate: toIso(exp.startDate),
  endDate: toIso(exp.endDate),
  description: exp.description,
}));
---

<AdminLayout title="Experiences" currentPath="/admin/experiences" user={user}>
  {error && <div class="admin-alert admin-alert-error">{error}</div>}

  <ExperiencesManager client:load experiences={rows} />
</AdminLayout>
