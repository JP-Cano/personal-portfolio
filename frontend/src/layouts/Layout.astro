---
import { ClientRouter } from "astro:transitions";
import ThemeProvider from "@/components/ThemeProvider.astro";
import "@/styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <ClientRouter />
    <ThemeProvider />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes"
    />
    <meta
      name="description"
      content="Personal portfolio of Juan Pablo Cano - Software Engineer"
    />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /*
   * Design tokens for "Luminous Depth". Light is :root (default); dark is the
   * hero and overrides under :root[data-theme="dark"]. Components must read
   * these via var(--token) (or Tailwind utilities bridged in global.css);
   * never hardcode hex except translucent shadows/scrims.
   */
  :root {
    /* Indigo -> violet -> blue gradient stops (the v1 palette). */
    --grad-1: #6366f1; /* indigo */
    --grad-2: #8b5cf6; /* violet */
    --grad-3: #3b82f6; /* blue   */

    --color-primary: #6366f1;
    --color-primary-dark: #4f46e5;
    --color-secondary: #8b5cf6;
    --color-accent: #3b82f6;

    --color-text: #1f2937;
    --color-text-light: #6b7280;
    --color-bg: #ffffff;
    --color-bg-alt: #f9fafb;
    --color-surface: #ffffff;
    --color-surface-2: #f3f4f6;
    --color-border: #e5e7eb;
    --color-border-strong: #d1d5db;
    --color-icon: #1f2937;

    --nav-surface: rgba(255, 255, 255, 0.85);

    --footer-grad-start: #1e1b4b;
    --footer-grad-end: #312e81;
    --footer-text: #ffffff;
    --footer-subtle: #a5b4fc;
    --footer-heading-grad-start: #ffffff;
    --footer-heading-grad-end: #c7d2fe;

    /* v1 typography: Inter body + Space Grotesk headings; logo keeps Clash. */
    --font-sans:
      "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    --font-display: "Space Grotesk", system-ui, sans-serif;
    --font-logo: "Clash Display", "Space Grotesk", system-ui, sans-serif;
    --font-mono: "JetBrains Mono", ui-monospace, "SFMono-Regular", monospace;

    --radius: 14px;
    --radius-sm: 8px;
    --radius-lg: 20px;
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  :root[data-theme="dark"] {
    /* Softer indigo/violet/blue against the deep navy base. */
    --grad-1: #818cf8; /* indigo */
    --grad-2: #a78bfa; /* violet */
    --grad-3: #60a5fa; /* blue   */

    --color-primary: #818cf8;
    --color-primary-dark: #6366f1;
    --color-secondary: #a78bfa;
    --color-accent: #60a5fa;

    --color-text: #e5e7eb;
    --color-text-light: #9ca3af;
    --color-bg: #0b1020;
    --color-bg-alt: #0f172a;
    --color-surface: #111827;
    --color-surface-2: #1f2937;
    --color-border: #1f2937;
    --color-border-strong: #374151;
    --color-icon: #e5e7eb;

    --nav-surface: rgba(17, 24, 39, 0.85);

    --footer-grad-start: #0b1020;
    --footer-grad-end: #151a2f;
    --footer-text: #e5e7eb;
    --footer-subtle: #9ca3af;
    --footer-heading-grad-start: #e5e7eb;
    --footer-heading-grad-end: #a5b4fc;
  }
</style>
