---
import { basics } from "@resume";
import Mail from "@/icons/Mail.astro";
import Phone from "@/icons/Phone.astro";

interface Props {
  email?: string;
  profiles?: typeof basics.profiles;
  socialMediaIcons: Record<string, any>;
}

const { email, profiles = [], socialMediaIcons } = Astro.props;
---

{
  email && (
    <a
      href={`mailto:${email}`}
      title={`Send email to ${email}`}
      aria-label={`Send email to ${email}`}
      class="bg-surface border-border text-text-light hover:text-primary hover:border-primary inline-flex h-10 w-10 items-center justify-center rounded-sm border p-1.5 transition-[color,border-color,transform] duration-[250ms] hover:-translate-y-0.5 motion-reduce:hover:translate-y-0"
    >
      <Mail />
    </a>
  )
}

{
  profiles.map(({ network, url, username }) => {
    const Icon = socialMediaIcons[network];
    if (!Icon) return null;
    return (
      <a
        href={url}
        title={`${network}: ${username}`}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Visit my ${network} profile`}
        class="bg-surface border-border text-text-light hover:text-primary hover:border-primary inline-flex h-10 w-10 items-center justify-center rounded-sm border p-1.5 transition-[color,border-color,transform] duration-[250ms] hover:-translate-y-0.5 motion-reduce:hover:translate-y-0"
      >
        <Icon />
      </a>
    );
  })
}
