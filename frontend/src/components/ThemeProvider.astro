---

<script is:inline>
  (function () {
    const THEME_KEY = "theme";
    const root = document.documentElement;

    function resolveTheme() {
      let stored;
      try {
        stored = localStorage.getItem(THEME_KEY);
      } catch (_) {
        /* localStorage unavailable */
      }

      let prefersDark = false;
      try {
        prefersDark =
          window.matchMedia &&
          window.matchMedia("(prefers-color-scheme: dark)").matches;
      } catch (_) {
        /* matchMedia unavailable */
      }

      return stored || (prefersDark ? "dark" : "light");
    }

    function applyTheme() {
      const theme = resolveTheme();
      if (root.getAttribute("data-theme") !== theme) {
        root.setAttribute("data-theme", theme);
      }

      let meta = document.querySelector('meta[name="color-scheme"]');
      if (!meta) {
        meta = document.createElement("meta");
        meta.setAttribute("name", "color-scheme");
        document.head.appendChild(meta);
      }
      meta.setAttribute(
        "content",
        theme === "dark" ? "dark light" : "light dark"
      );
    }

    function toggle() {
      const next =
        root.getAttribute("data-theme") === "dark" ? "light" : "dark";
      root.setAttribute("data-theme", next);
      try {
        localStorage.setItem(THEME_KEY, next);
      } catch (_) {
        /* localStorage unavailable */
      }
      const meta = document.querySelector('meta[name="color-scheme"]');
      if (meta) {
        meta.setAttribute(
          "content",
          next === "dark" ? "dark light" : "light dark"
        );
      }
      window.dispatchEvent(
        new CustomEvent("theme:changed", { detail: { theme: next } })
      );
    }

    // Apply theme on initial load
    applyTheme();

    window.addEventListener("theme:toggle", toggle);

    window.addEventListener("storage", function (e) {
      if (e.key === THEME_KEY && e.newValue) {
        root.setAttribute("data-theme", e.newValue);
        const meta = document.querySelector('meta[name="color-scheme"]');
        if (meta) {
          meta.setAttribute(
            "content",
            e.newValue === "dark" ? "dark light" : "light dark"
          );
        }
        window.dispatchEvent(
          new CustomEvent("theme:changed", { detail: { theme: e.newValue } })
        );
      }
    });

    // Re-apply theme after View Transitions (Astro ClientRouter)
    document.addEventListener("astro:page-load", applyTheme);

    try {
      const media = window.matchMedia("(prefers-color-scheme: dark)");
      if (media.addEventListener) {
        media.addEventListener("change", function (e) {
          try {
            const stored = localStorage.getItem(THEME_KEY);
          } catch (_) {
            /* localStorage unavailable */
          }
          if (!stored) {
            const next = e.matches ? "dark" : "light";
            root.setAttribute("data-theme", next);
            const meta = document.querySelector('meta[name="color-scheme"]');
            if (meta) {
              meta.setAttribute(
                "content",
                next === "dark" ? "dark light" : "light dark"
              );
            }
            window.dispatchEvent(
              new CustomEvent("theme:changed", { detail: { theme: next } })
            );
          }
        });
      }
    } catch (_) {
      /* matchMedia unavailable */
    }
  })();
</script>
