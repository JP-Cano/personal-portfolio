---
interface Props {
  title?: string;
  id?: string;
  index?: number;
}

const { title, id, index } = Astro.props;
const sectionNumber = index != null ? String(index).padStart(2, "0") : null;
---

<section
  class="content-section fade-in relative px-5 py-16 md:px-8 md:py-24"
  id={id}
>
  <div class="mx-auto w-full max-w-[1180px]">
    {
      title && (
        <header class="relative mb-10 text-center md:mb-14">
          <span class="section-glow" aria-hidden="true" />
          {sectionNumber && (
            <span class="eyebrow eyebrow-accent relative z-[1] mb-3 block">
              {sectionNumber}
            </span>
          )}
          <h2 class="relative z-[1] m-0 text-[clamp(1.9rem,4vw,2.6rem)]">
            {title}
          </h2>
          <span class="aurora-rule relative z-[1] mx-auto mt-6 block max-w-[80px]" />
        </header>
      )
    }
    <div>
      <slot />
    </div>
  </div>
</section>
