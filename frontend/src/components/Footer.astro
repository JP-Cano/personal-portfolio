---
import { basics } from "@resume";
import ContactLinks from "@/components/ContactLinks.astro";
import GitHub from "@/icons/GitHub.astro";
import LinkedIn from "@/icons/LinkedIn.astro";

const { email, profiles } = basics;
const currentYear = new Date().getFullYear();

const SOCIAL_MEDIA_ICONS: Record<string, any> = {
  LinkedIn,
  GitHub,
};
---

<footer
  class="relative mt-24 bg-[var(--footer-grad-start)] px-8 pt-16 pb-8 text-[var(--footer-text)] max-md:px-6 max-md:pt-12 max-md:pb-6"
  id="contact"
>
  <div class="aurora-rule absolute top-0 left-0 w-full"></div>
  <div class="mx-auto max-w-[1180px]">
    <div
      class="mb-12 grid [grid-template-columns:repeat(auto-fit,minmax(220px,1fr))] gap-12 max-md:grid-cols-1 max-md:gap-8"
    >
      <div>
        <span class="eyebrow mb-[0.6rem] block">Contact</span>
        <h3 class="mb-[0.85rem] text-[1.4rem]">
          <span class="aurora-text">Juan Pablo Cano</span>
        </h3>
        <p class="max-w-[36ch] leading-[1.6] text-[var(--footer-subtle)]">
          Backend engineer focused on reliable APIs, event pipelines, and the
          services behind them.
        </p>
      </div>

      <div>
        <h4 class="eyebrow mb-[1.1rem] block">Navigation</h4>
        <ul class="m-0 p-0">
          <li class="mb-[0.55rem]">
            <a
              href="#about"
              class="hover:text-primary font-sans text-[0.9rem] text-[var(--footer-subtle)] transition-colors duration-300"
              >About</a
            >
          </li>
          <li class="mb-[0.55rem]">
            <a
              href="#experience"
              class="hover:text-primary font-sans text-[0.9rem] text-[var(--footer-subtle)] transition-colors duration-300"
              >Experience</a
            >
          </li>
          <li class="mb-[0.55rem]">
            <a
              href="#projects"
              class="hover:text-primary font-sans text-[0.9rem] text-[var(--footer-subtle)] transition-colors duration-300"
              >Projects</a
            >
          </li>
          <li class="mb-[0.55rem]">
            <a
              href="#skills"
              class="hover:text-primary font-sans text-[0.9rem] text-[var(--footer-subtle)] transition-colors duration-300"
              >Skills</a
            >
          </li>
        </ul>
      </div>

      <div>
        <h4 class="eyebrow mb-[1.1rem] block">Connect</h4>
        <div class="mt-1 flex flex-wrap gap-2">
          <ContactLinks
            email={email}
            profiles={profiles}
            socialMediaIcons={SOCIAL_MEDIA_ICONS}
          />
        </div>
      </div>
    </div>

    <div class="border-border border-t pt-8">
      <p
        class="m-0 font-mono text-[0.78rem] tracking-[0.02em] text-[var(--footer-subtle)]"
      >
        &copy; {currentYear} Juan Pablo Cano. All rights reserved.
      </p>
    </div>
  </div>
</footer>
