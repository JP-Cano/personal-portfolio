---
import { ENVIRONMENT } from "astro:env/server";

const { hasError, error, data } = Astro.props;
---

{
  hasError && (
    <div class="mb-8 rounded-[var(--radius)] border border-[#e5614b]/40 bg-[#e5614b]/10 px-6 py-8 text-center">
      <p class="m-0 font-semibold text-[#e5614b]">
        Unable to load information. Please try again later.
      </p>
      {ENVIRONMENT === "local" && (
        <p class="mt-4 rounded-sm bg-black/20 p-2 font-mono text-sm break-all text-[#e5614b]">
          {error?.toString()}
        </p>
      )}
    </div>
  )
}

{
  !hasError && (!data || data.length === 0) && (
    <div class="text-text-light px-8 py-12 text-center">
      <p class="m-0 text-lg">No data to display yet.</p>
    </div>
  )
}
